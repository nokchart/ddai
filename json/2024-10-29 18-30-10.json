  "textdic": {
    "21600\t24871.975\t20\t217": "휜휜\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t",
    "24881.754\t24926.518\t178\t0": "갑자기 둘이ㅋㅋㅋㅋ\t뭐야 ㅋㅋㅋ",
    "24926.518\t24985.556999999997\t130\t0": "너가 싫다\t난 너가 싫다\t젠장 너가 싫다",
    "24985.556999999997\t25041.578\t100\t0": "피리의 해머화\t피리(해머)\t피리 = 소리나는 해머",
    "25041.578\t25085.731\t64\t0": "ㅋㅋㅋㅋㅋㅋㅋ 맞기만하는디\t피리가 좋은 몬스터가 있나요",
    "25085.731\t25137.647\t40\t0": "무기가\t해머가 시원시원하네요\t데미지가 ㅋㅋㅋ",
    "25137.647\t25175.273\t54\t0": "피리의 해머화\t이사람 피리 안해봐서 피리시스템 잘 모름 ㅋㅋ",
    "25175.273\t25231.11\t72\t0": "그냥 해머네\t이게 해머지\t소리나는 해머",
    "25231.11\t25277.145\t56\t0": "어그로\tㄷㄷㄷ 소리 느!\t꼬양이가 어그로중",
    "25277.145\t25323.686\t80\t0": "6\t6 6 들어감\t나서스 ㅋㅋㅋㅋㅋㅋㅋㅋ",
    "25323.686\t25358.902000000002\t70\t1": "장판에 함정깔아야겠는데?\t",
    "25358.902000000002\t25394.426\t36\t1": "가서맞기\t",
    "25394.426\t25445.048\t66\t0": "런\t사람 들어와서\t상쇄 된건가?",
    "25445.048\t25476.64\t58\t0": "상처인가\t상처가 세개",
    "25476.64\t25518.178\t74\t0": "장판 너무 좁다\t장판에서 멀다",
    "25518.178\t25563.024\t92\t0": "'장판'\t장판 겁나 깔아야것네",
    "25563.024\t25608.623\t98\t0": "영역전개\t영역전개중\t나갔다",
    "25608.623\t25644.544\t94\t0": "갓겜 ㄷㄷ\t버그갓겜",
    "25644.544\t25689.416\t132\t0": "스킬있을듯\t장판 크기 키우는 스킬 있을듯",
    "25689.416\t25721.942\t78\t0": "클러치없음\t장판을 여러개 깔죠",
    "25721.942\t25745.679\t80\t0": "7시간 ㅋㅋㅋ"
  },
