  "textdic": {
    "22.25\t59.326\t56\t0": "ㄴㅋㄴㅋ\tㄴㅋ",
    "59.326\t109.73100000000001\t74\t0": "ㄴㅋㄴㅋ\t녹하\t춘천광역시",
    "109.73100000000001\t144.94199999999998\t32\t1": "ㄴㅋ\t",
    "149.285\t202.192\t36\t0": "밖에 춘천인데요?\t저게 춘천야경인가\tㄸㅇ",
    "202.192\t238.614\t48\t0": "별자리 있네 ㅋㅋㅋ\t룬키 별자리도있었네",
    "238.614\t287.96099999999996\t160\t0": "ㅎㅇㅇ\t잘 지내셨습니다\t잘들 지내셨는지요~",
    "287.96099999999996\t327.646\t56\t0": "나태두로\t녹하",
    "327.646\t380.015\t84\t0": "아니근데\t윽\t유언이 아니근데",
    "380.015\t404.049\t46\t0": "ㅎㅅ",
    "404.049\t449.177\t156\t0": "한스 했음\t한스\t? 싫긴 싫다?",
    "449.177\t484.719\t178\t0": "'스'며들다..\t너 스며든거야",
    "484.719\t522.618\t208\t0": "똥ㅋㅋ\t과해",
    "522.618\t572.555\t134\t0": "고닉\t싸닉\t흑싸닉",
    "572.555\t621.073\t144\t0": "소파 ㅋㅋㅋㅋㅋ\t소파 방정환\t니가 있던 소파",
    "621.073\t673.1279999999999\t76\t0": "ㄸㅇ\t소닉은 신작 꾸준히 나왔으니까요\t건방ㅋㅋㅋㅋㅋㅋㅋㅋㅋㅋㅋ",
    "673.1279999999999\t706.955\t84\t0": "똥을 왜 ㄷㄷ\t똥섭취 ㅋㅋㅋ",
    "706.955\t763.107\t116\t0": "장발두로ㄷㄷ\t장발\t두로도 안먹는 ㅋㅋㅋㅋ",
    "763.107\t810.1990000000001\t92\t0": "머리묶어요\t머리면도 ㄷㄷ\t청순한 머리",
    "810.1990000000001\t859.417\t104\t0": "갔어...\t진짜길다ㅋㅋㅋ\t진짜 많이 길렀네",
    "859.417\t902.896\t214\t0": "롤\tㅃ~",
    "902.896\t961.713\t242\t0": "지금은...?\t눈도 먹나요\t지금은 맹금류의 눈",
    "968.41\t1025.196\t164\t0": "스미골 스미골\t스미골 2배\t더블 스미골",
    "1025.196\t1061.648\t72\t0": "모텔가죠\t집놔두고 모텔가서 자기",
    "1061.648\t1107.527\t120\t0": "선풍기는 왜 틀고 자시나요\t그땐 젊었어\t선풍기틀고 자면 죽는다 이런건가요",
    "1107.527\t1158.2169999999999\t144\t0": "앵무집\t앵무를 방음부스에?\t방음부스에서",
    "1167.93\t1226.803\t152\t0": "잘먹네\t슨고도 먹나\t비난앵무",
    "1226.803\t1270.051\t190\t0": "똥\t또 등반이야",
    "1270.051\t1316.27\t186\t0": "이게 뭐야 ㅋㅋ\t이게 스노우브라더스?\t저게 뭐야 ㅋㅋㅋㅋ",
    "1316.27\t1363.741\t104\t0": "이 상 현 상\t개이름 쭈이\t쭈이",
    "1363.741\t1384.253\t64\t0": "키위",
    "1384.253\t1434.754\t218\t0": "키위\t<<<<<<<안봄\t재밌음",
    "1434.754\t1460.9969999999998\t208\t0": "따라",
    "1460.9969999999998\t1518.3129999999999\t278\t0": "하긴\t뒷렁키는 하시면서\t방송각",
    "1518.3129999999999\t1540.708\t244\t0": "뒷롤 ㄷㄷ",
    "1540.708\t1595.198\t152\t0": "진짜들의 시간\t악귀들의 시간\t아기조직",
    "1595.198\t1645.002\t146\t0": "대 두 로ㅋㅋㅋ\t안읽음ㅋㅋㅋㅋㅋㅋㅋㅋㅋ\t결계 ㅋㅋ",
    "1645.002\t1700.016\t158\t0": "너굴맨\t이거좋네요\t똥냄새가 난다 이거 하실듯",
    "1700.016\t1740.662\t188\t0": "람쥐 ㄷㄷ\t람쥐썬더 ㄷㄷ",
    "1740.662\t1799.031\t216\t0": "그건 하늘다람쥐\t하늘다람쥐만\t그건 하늘다람쥐 아닌가",
    "1799.031\t1854.142\t194\t0": "아파트아파트아파트아파트아파트\t아파트 노래\t큿",
    "1854.142\t1884.418\t156\t0": "메타버스\t이것이 메타버스",
    "1884.418\t1926.509\t262\t0": "롤?\t롤하실?",
    "1926.509\t1979.539\t344\t0": "ㅃ\t42분?\t42분안에?",
    "1979.539\t2041.1899999999998\t206\t0": "ㅃ\tㅃ손실\tㅃ~~~~~!!!!!!!!!!!!\tㅃ손실 어쩔 거여",
    "2046.415\t2106.238\t54\t2": "ㅁ?ㄹ\t\t",
    "2106.238\t2157.038\t82\t0": "^^7\t^^^7\t치지직은 연장 안될거임",
    "2157.038\t2203.1500000000005\t66\t0": "제트팩 그렇게 나오는거 처음봄\t그리고 첫판 제트팩\t제트팩 그렇게 많이 나오는거 처음봄ㅋㅋㅋ",
    "2203.1500000000005\t2251.879\t60\t0": "ㅃ\tㅠㅠㅠㅠ\t쫄가이즈 ㅋㅋㅋ",
    "2251.879\t2290.446\t64\t0": "녹두핑\t머시기",
    "2290.446\t2336.743\t104\t0": "77\t77ㅓ억\t77ㅓ억핑ㄷㄷ",
    "2336.743\t2369.428\t42\t0": "꺼억 미션?\t히든미션 꺼억",
    "2369.428\t2394.08\t38\t0": "ㄹㅇ"
